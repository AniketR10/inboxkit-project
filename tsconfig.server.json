{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2019",
    "noEmit": false,           
    "outDir": "dist",          
    "isolatedModules": false,
    "esModuleInterop": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules"]
}